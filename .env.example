# ============================================================
# SlackHive — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Claude Code Authentication ---
# Option 1: API Key (pay-per-use via Anthropic API)
# ANTHROPIC_API_KEY=sk-ant-api03-...
#
# Option 2: Claude Code Subscription (Max plan)
# Don't set ANTHROPIC_API_KEY. Instead, run `claude login` on your
# host machine and mount ~/.claude into the runner container.
# See README for details.

# --- Database ---
POSTGRES_DB=agentteam
POSTGRES_USER=agentteam
POSTGRES_PASSWORD=change_me_in_production

# --- Auth (web UI login) ---
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=changeme
# AUTH_SECRET=change-this-secret-in-production

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Platform ---
NODE_ENV=development
